<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:elevation="4dp">

        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/primary"
            android:title="@string/app_name"
            android:titleTextColor="@color/white"
            app:titleTextAppearance="@style/ToolbarTitle" />

        <!-- Stats Bar -->
        <TextView
            android:id="@+id/tv_stats"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@color/primary_dark"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:text="Loading..."
            android:textColor="@color/white"
            android:textSize="12sp"
            android:gravity="center" />

    </com.google.android.material.appbar.AppBarLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <!-- Search Bar -->
        <EditText
            android:id="@+id/et_search"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_margin="12dp"
            android:background="@drawable/bg_search"
            android:drawableStart="@drawable/ic_search"
            android:drawablePadding="8dp"
            android:hint="Search learner, parent, class..."
            android:imeOptions="actionSearch"
            android:inputType="text"
            android:paddingHorizontal="12dp"
            android:singleLine="true"
            android:textSize="14sp" />

        <!-- Action Buttons Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp"
            android:paddingBottom="8dp">

            <Button
                android:id="@+id/btn_bulk_sms"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:drawableStart="@drawable/ic_sms"
                android:drawablePadding="4dp"
                android:text="Bulk SMS"
                android:textSize="12sp" />

            <Button
                android:id="@+id/btn_history"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:drawableStart="@drawable/ic_history"
                android:drawablePadding="4dp"
                android:text="History"
                android:textSize="12sp" />

        </LinearLayout>

        <!-- Learner Count -->
        <TextView
            android:id="@+id/tv_section_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="16dp"
            android:paddingBottom="4dp"
            android:text="Learners"
            android:textColor="@color/primary"
            android:textSize="13sp"
            android:textStyle="bold" />

        <!-- Empty State -->
        <TextView
            android:id="@+id/tv_empty"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:padding="48dp"
            android:text="No learners yet.\nTap ＋ to add your first learner."
            android:textColor="@color/text_secondary"
            android:textSize="15sp"
            android:visibility="gone" />

        <!-- Learner List -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recycler_learners"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="80dp" />

    </LinearLayout>

    <!-- FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_add"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="16dp"
        android:contentDescription="Add Learner"
        android:src="@drawable/ic_add"
        app:backgroundTint="@color/accent"
        app:tint="@color/white" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
